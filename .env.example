# Venture Home Solar — Expense Tracker
# Copy to .env.local for local dev. Do NOT commit .env.local.
# Production values are set on Cloud Run via:
#   gcloud run services update venture-home-expense-tracker --region us-east1 \
#     --update-env-vars="KEY=value,KEY2=value2"

# Phase 1 is fully mock-driven. These are placeholders for Phase 2/3 integrations.
VITE_APP_MODE=mock

# OCR (Phase 2)
VITE_OCR_PROVIDER=
VITE_OCR_API_KEY=

# Sage Intacct (Phase 3)
SAGE_INTACCT_API_URL=
SAGE_INTACCT_CLIENT_ID=
SAGE_INTACCT_CLIENT_SECRET=

# CoAdvantage payroll (Phase 3)
COADVANTAGE_API_URL=
COADVANTAGE_API_KEY=

# Google Cloud Storage bucket for receipt images (Phase 2)
GCS_RECEIPT_BUCKET=
